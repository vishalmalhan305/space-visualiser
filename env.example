# ==========================================
# Space Visualiser - Environment Configuration Template
# ==========================================
# Copy this file to .env and fill in your values

# PostgreSQL Configuration
POSTGRES_DB=spacedb
POSTGRES_USER=space
POSTGRES_PASSWORD=space123
POSTGRES_PORT=5433          # Use 5433 if local PostgreSQL is on 5432

# Redis Configuration
REDIS_PORT=6379
# REDIS_PASSWORD=          # Optional: Set password for production

# Backend Configuration
BACKEND_PORT=8080

# NASA API Configuration
NASA_API_KEY=DEMO_KEY      # Get your free key: https://api.nasa.gov

# Anthropic API Configuration (Phase 3)
# ANTHROPIC_API_KEY=       # Get key: https://console.anthropic.com

# JVM Configuration
JAVA_OPTS=-Xmx512m -Xms256m

# Logging
LOG_LEVEL=INFO
APP_LOG_LEVEL=DEBUG